    "baidu": {
      "label": "Baidu Search",
      "url": "https://www.baidu.com",
      "enabled": false,
      "_comment": "Set enabled:true to include Baidu in status checks"
    }
  },
  "energy": {
    "kwh_rate_usd": 0.22,
    "_comment": "Electricity cost per kWh in USD — Long Beach CA rate"
